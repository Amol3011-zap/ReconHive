# ===== CORE APPLICATION =====
DATABASE_URL=postgresql://user:password@localhost:5432/reconhive
SQL_ECHO=false
DEBUG=false
LOG_LEVEL=INFO

# ===== SECURITY =====
JWT_SECRET_KEY=change_me_in_production_to_secure_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== DATABASE =====
DB_USER=reconhive_user
DB_PASSWORD=secure_password_change_me
DB_NAME=reconhive

# ===== REDIS & CELERY =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===== EMAIL (MAILPIT) =====
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@reconhive.local
SMTP_TLS=false

# ===== PGADMIN =====
PGADMIN_EMAIL=admin@reconhive.local
PGADMIN_PASSWORD=admin

# ===== GRAFANA =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ===== PROMETHEUS =====
PROMETHEUS_RETENTION=15d

# ===== MONITORING =====
ENVIRONMENT=development
SERVICE_NAME=reconhive
MONITORING_ENABLED=true
